# =============================================================================
# EVOBRAIN - CONFIGURAÇÃO COMPLETA
# =============================================================================

# -----------------------------------------------------------------------------
# DOMÍNIO (usuário escolhe)
# -----------------------------------------------------------------------------
DOMAIN_TYPE=custom
DOMAIN_NAME=Meu Domínio
DOMAIN_DESCRIPTION=Descrição do domínio
DOMAIN_ACTIONS=[{"id":0,"name":"ACAO_A","color":"🔴","emoji":"🔴"},{"id":1,"name":"ACAO_B","color":"🔵","emoji":"🔵"}]

# -----------------------------------------------------------------------------
# LLM (usuário escolhe)
# -----------------------------------------------------------------------------
LLM_TYPE=ollama
LLM_MODEL=llama3.2
LLM_HOST=http://localhost:11434
LLM_API_KEY=
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT=30

# -----------------------------------------------------------------------------
# FONTE DE DADOS (usuário escolhe)
# -----------------------------------------------------------------------------
DATA_SOURCE_TYPE=custom
DATA_SOURCE_ENABLED=true
DATA_SOURCE_INTERVAL=0.5
DATA_SOURCE_REST_URL=
DATA_SOURCE_REST_METHOD=GET
DATA_SOURCE_REST_HEADERS={}
DATA_SOURCE_REST_PARAMS={}
DATA_SOURCE_REST_MAPPING={}
DATA_SOURCE_WS_URL=
DATA_SOURCE_WS_HEADERS={}

# -----------------------------------------------------------------------------
# AGENTES
# -----------------------------------------------------------------------------
MAX_AGENTS=10000
STATE_SIZE=150
AGENT_CREATION_DELAY=0.5
INITIAL_AGENTS=100

# -----------------------------------------------------------------------------
# RL
# -----------------------------------------------------------------------------
LEARNING_RATE=0.001
GAMMA=0.99
EPSILON_START=0.3
EPSILON_MIN=0.05
EPSILON_DECAY=0.9995
BATCH_SIZE=64
MEMORY_SIZE=10000

# -----------------------------------------------------------------------------
# PRIORITIZED REPLAY
# -----------------------------------------------------------------------------
REPLAY_BUFFER_SIZE=100000
REPLAY_ALPHA=0.6
REPLAY_BETA=0.4

# -----------------------------------------------------------------------------
# NEUROEVOLUTION
# -----------------------------------------------------------------------------
MUTATION_RATE=0.1
ELITE_PERCENT=0.2
CROSSOVER_RATE=0.7
POPULATION_SIZE=1000

# -----------------------------------------------------------------------------
# MEMÓRIA
# -----------------------------------------------------------------------------
EPISODIC_MEMORY_SIZE=100
LONG_TERM_MEMORY_SIZE=10000
MEMORY_DECAY_RATE=0.01
MEMORY_CONSOLIDATION_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# COMPETIÇÃO
# -----------------------------------------------------------------------------
COMPETITION_ELO_K=32
COMPETITION_KEEP_RATIO=0.3
TOURNAMENT_ROUNDS=3

# -----------------------------------------------------------------------------
# APRENDIZADO CONTÍNUO
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
CONTINUOUS_LEARNING_ENABLED=true
CONTINUOUS_LEARNING_INTERVAL=5

# -----------------------------------------------------------------------------
# BANCO DE DADOS
# -----------------------------------------------------------------------------
DATABASE_ENABLED=false
DATABASE_URL=

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# FRONTEND
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
FRONTEND_TITLE=EvoBrain
FRONTEND_THEME=dark
