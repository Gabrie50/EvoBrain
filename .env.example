# LLM Local (Ollama)
LLM_MODEL=llama3.2
LLM_HOST=http://localhost:11434
LLM_TIMEOUT=30

# Agentes
MAX_AGENTS=10000
STATE_SIZE=150
AGENT_CREATION_DELAY=0.5

# RL
LEARNING_RATE=0.001
GAMMA=0.99
EPSILON_START=0.3
EPSILON_MIN=0.05
EPSILON_DECAY=0.9995
BATCH_SIZE=64
MEMORY_SIZE=10000

# Neuroevolution
MUTATION_RATE=0.1
ELITE_PERCENT=0.2
CROSSOVER_RATE=0.7

# Simulação
PREDICTION_INTERVAL=0.5
HISTORY_SIZE=5000
FEEDBACK_DELAY=0.1

# Banco de Dados
DATABASE_URL=postgresql://evobrain:evobrain123@postgres:5432/evobrain

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Frontend
FRONTEND_URL=http://localhost:3000

# Data Collector (Bac Bo)
BACBO_API_URL=https://api-cs.casino.org/svc-evolution-game-events/api/bacbo
BACBO_WS_URL=wss://api-cs.casino.org/svc-evolution-game-events/ws/bacbo
API_TIMEOUT=5
API_RETRIES=3
